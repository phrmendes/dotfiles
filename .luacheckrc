std = "max"

globals = {
  "vim",
  "hl",
  "safely",
  "Snacks",
  "MiniPick",
  "MiniIcons",
  "MiniNotify",
  "MiniCompletion",
  "MiniKeymap",
  "MiniMisc",
  "MiniSnippets",
  "MiniFiles",
  "MiniTrailspace",
  "MiniVisits",
  "MiniExtra",
  "MiniBufremove",
  "MiniDiff",
  "MiniDoc",
  "MiniTabline",
  "MiniTest",
  "MiniSessions",
}

max_line_length = 150

exclude_files = {
  "neovim/plugins/",
}
